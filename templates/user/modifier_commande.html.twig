{#modification commande, variable:commande->obj Commande à modifier, menu peut pas être changé & prix recalculé côté serveur après modif#}

{% extends 'base.html.twig' %}

{% block title %}Modifier ma commande — Vite & Gourmand{% endblock %}

{% block page_css %}
    <link rel="stylesheet" href="{{ asset('css/forms.css') }}">
{% endblock %}

{% block body %}

<div class="hero-bandeau">
    <h1 class="hero-titre">Modifier ma commande</h1>
</div>

<section class="section-commande">
    <div class="container-xl px-4 w-100" style="max-width:660px">

        {#lien retour#}
        <a href="{{ path('app_user_dashboard') }}" class="lien-retour">
            ← Retour à mes commandes
        </a>

        <div class="login-card mt-2">

            {# Rappel menu non modifiable #}
            <div class="form-rappel mb-4">
                <p class="form-rappel-texte">
                    Menu : <strong>{{ commande.menu.titre }}</strong>
                </p>
                <p class="form-hint">Le menu ne peut pas être modifié.</p>
            </div>

            <form method="post">

                {#csrf#}
                <input type="hidden" name="_token"
                       value="{{ csrf_token('modifier_commande') }}">

                <div class="row g-3">

                    {#adresse pré-remplie commande #}
                    <div class="col-12">
                        <label class="form-label">Adresse de livraison *</label>
                        <input type="text"
                               name="adresse_livraison"
                               class="form-control"
                               value="{{ commande.adresseLivraison }}"
                               required>
                    </div>

                    {#ville, frais de livraison (recalculés côté serveur) #}
                    <div class="col-md-6">
                        <label class="form-label">Ville *</label>
                        <input type="text"
                               name="ville_livraison"
                               class="form-control"
                               value="{{ commande.villeLivraison }}"
                               required>
                        <div class="form-hint">Livraison gratuite à Bordeaux · +5€ ailleurs</div>
                    </div>

                    {#nb personnes conditionne réduc° 10% #}
                    <div class="col-md-6">
                        <label class="form-label">Nombre de personnes *</label>
                        <input type="number"
                               name="nb_personnes"
                               class="form-control"
                               value="{{ commande.nbPersonnes }}"
                               min="{{ commande.menu.nbPersonnesMin }}"
                               required>
                        <div class="form-hint">
                            Minimum : {{ commande.menu.nbPersonnesMin }} personnes
                        </div>
                    </div>

                    {#date presta°, min = aujourd'hui #}
                    <div class="col-md-6">
                        <label class="form-label">Date de prestation *</label>
                        <input type="date"
                               name="date_prestation"
                               class="form-control"
                               value="{{ commande.datePrestation|date('Y-m-d') }}"
                               required>
                    </div>

                    {#heure livraison #}
                    <div class="col-md-6">
                        <label class="form-label">Heure de livraison *</label>
                        <input type="time"
                               name="heure_livraison"
                               class="form-control"
                               value="{{ commande.heureLivraison|date('H:i') }}"
                               required>
                    </div>

                </div>

                {#btn #}
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-vert">
                        Enregistrer les modifications
                    </button>
                    <a href="{{ path('app_user_dashboard') }}"
                       class="btn btn-outline-secondary">
                        Annuler
                    </a>
                </div>

            </form>
        </div>
    </div>
</section>

{% endblock %}