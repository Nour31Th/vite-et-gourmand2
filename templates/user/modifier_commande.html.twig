{#modification commande, variable:commande->obj Commande à modifier, menu peut pas être changé & prix recalculé côté serveur après modif#}

{% extends 'base.html.twig' %}

{% block title %}Modifier ma commande — Vite & Gourmand{% endblock %}

{% block page_css %}
    <link rel="stylesheet" href="{{ asset('css/forms.css') }}">
{% endblock %}

{% block body %}

<div class="hero-bandeau-page">
    <h1 class="hero-bandeau-titre">Modifier ma commande</h1>
</div>

<section class="section-commande">
    <div class="container-xl px-4">

        <a href="{{ path('app_user_dashboard') }}" class="lien-retour">
            ← Retour à mes commandes
        </a>

        <div class="row justify-content-center mt-3">
            <div class="col-12 col-md-8">
                <div class="commande-card">

                    {#rappel menu non modifiable#}
                    <div class="recap-menu mb-4 p-3 bg-light rounded">
                        <div class="recap-menu-label">Menu commandé (non modifiable)</div>
                        <div class="recap-menu-titre">{{ commande.menu.titre }}</div>
                        <div class="recap-menu-info">
                            {{ commande.menu.theme }} — {{ commande.menu.regime }}
                        </div>
                    </div>

                    <form action="{{ path('app_user_modifier_commande', {id: commande.id}) }}"
                          method="post">

                        {#token csrf#}
                        <input type="hidden"
                               name="_token"
                               value="{{ csrf_token('modifier_' ~ commande.id) }}">

                        {#adresse pré-remplie #}
                        <div class="mb-3">
                            <label for="adresse_livraison" class="form-label">
                                Adresse de livraison *
                            </label>
                            <input type="text"
                                   id="adresse_livraison"
                                   name="adresse_livraison"
                                   class="form-control"
                                   value="{{ commande.adresseLivraison }}"
                                   required>
                        </div>

                        <div class="row">
                            {#ville pré-remplie #}
                            <div class="col-md-6 mb-3">
                                <label for="ville_livraison" class="form-label">
                                    Ville *
                                </label>
                                <input type="text"
                                       id="ville_livraison"
                                       name="ville_livraison"
                                       class="form-control"
                                       value="{{ commande.villeLivraison }}"
                                       required>
                                <div class="form-text">
                                    Livraison gratuite à Bordeaux · +5 € ailleurs
                                </div>
                            </div>

                            {#nb pers pré-rempli #}
                            <div class="col-md-6 mb-3">
                                <label for="nb_personnes" class="form-label">
                                    Nombre de personnes *
                                    <span class="form-text">(min. {{ commande.menu.nbPersonnesMin }})</span>
                                </label>
                                <input type="number"
                                       id="nb_personnes"
                                       name="nb_personnes"
                                       class="form-control"
                                       min="{{ commande.menu.nbPersonnesMin }}"
                                       value="{{ commande.nbPersonnes }}"
                                       required>
                            </div>
                        </div>

                        <div class="row">
                            {#date presta° pré-remplie #}
                            <div class="col-md-6 mb-3">
                                <label for="date_prestation" class="form-label">
                                    Date de prestation *
                                </label>
                                <input type="date"
                                       id="date_prestation"
                                       name="date_prestation"
                                       class="form-control"
                                       value="{{ commande.datePrestation|date('Y-m-d') }}"
                                       min="{{ "now"|date("Y-m-d") }}"
                                       required>
                            </div>

                            {#heure livraison pré-remplie #}
                            <div class="col-md-6 mb-3">
                                <label for="heure_livraison" class="form-label">
                                    Heure de livraison *
                                </label>
                                <input type="time"
                                       id="heure_livraison"
                                       name="heure_livraison"
                                       class="form-control"
                                       value="{{ commande.heureLivraison|date('H:i') }}"
                                       required>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-2">
                            <button type="submit" class="btn btn-vert">
                                Enregistrer les modifications
                            </button>
                            <a href="{{ path('app_user_dashboard') }}"
                               class="btn btn-outline-secondary">
                                Annuler
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}