{# template pr tte l'appli, présent ds les autres templates --> via{% extends 'base.html.twig' %} 
   Blocs ici : title -> titre onglet,  page_css-> css spécifique page , body->contenu , page_js->js de la page
#}

<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        {# meta description pr SEO#}
        <meta name="viewport" content="width=device-width, intial-scale=1.0">
        <meta name="description" content="Vite & Gourmand -Traiteur livraison à domicile Bordeaux">
        
        <title>{% block title %}Vite et Gourmand{% endblock %}</title>
        
        {# logo onglet navigateur #} 
        <link rel="icon" href="{{ asset('images/logo.svg') }}">

        {# police google fonts #} 
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Poppins:wght@400;600&family=Open+Sans:wght@600&family=Lato:wght@400;700&family=Roboto:wght@700&family=Lexend:wght@400;500&display=swap" rel="stylesheet">
        
        {# css bootstrap5 w/ cdn #} 
        <link href ="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"> 
    
        {#fichier css de tte l'appli#}
        <link rel="stylesheet" href="{{ asset('css/app.css') }}">

        {# css spécifique pr pages enfants et ici vide par défaut#}
        {% block page_css %} {%endblock%}
    </head>
    <body>

      {#lien evitement accessblité pr améliorer experience utilisateur #} 
      <a href="#main" class="visually-hidden-focusable">Aller au contenu principal</a>

      {# ici la navbar #}
        <nav class="navbar navbar-expand-lg bg-white border-bottom" aria-label="Navigation principale">
           <div class="container-xl px-4">
             <div class="navbar-inner">
                
               {# btn menu hamburger mobile#}
               <button class="navbar-toggler d-lg-none border-0 p-0"
                       type="button"
                       data-bs-toggle="collapse"
                       data-bs-target="#navMenu"
                       aria-controls="navMenu"
                       aria-expanded="false"
                       aria-label="Ouvrir le menu">
                 <span class="navbar-toggler-icon"></span>
               </button>

               {# logo#}
                <a href="{{ path ('app_home') }}" class="navbar-logo">
                     <img src="{{ asset ('images/logo.svg') }}"
                         alt="Logo vite et Gourmand"
                         class="navbar-logo-img">
                </a>
               
               {#menu desktop#}
               <div class="navbar-liens d-none d-lg-flex align-items-center gap-2">
                  <a href="{{ path('app_home') }}" class="nav-link">Accueil</a>
                  <a href="{{ path('app_menu_index') }}" class="nav-link">Nos menus</a>
                  <a href="{{ path('app_avis_liste') }}" class="nav-link">Vos avis</a>
                  <a href="#" class="nav-link">Aide</a>
                  <a href="{{ path('app_contact') }}" class="nav-link">Contact</a>
               </div>

              {#btn selon connex° rôle et barre recherche #}
              <div class="navbar-droite d-none d-lg-flex align-items-center gap-3">
                
                {#barre recherche#}
                <div class="navbar-search">
                   <input type="search"
                          placeholder="Recherche"
                          class="navbar-search-input">
                </div>

                {% if app.user %}
                    {#connecté#}
                    {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_dashboard') }}" class="navbar-icon" title="Admin">
                               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </a>
                    {% elseif is_granted('ROLE_EMPLOYE') %}
                            <a href="{{ path('app_employe_dashboard') }}" class="navbar-icon" title="Employé">
                               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </a>
                    {% else %}
                            <a href="{{ path('app_user_dashboard') }}" class="navbar-icon" title="Mon compte">
                               <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </a>
                    {% endif %}
                        <a href="{{ path('app_logout') }}" class="nav-link">Déconnexion</a>
                {% else %}
                    {#client pas connecté #}
                        <a href="{{ path('app_login') }}" class="navbar-icon" title="Connexion">
                           <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </a>
                {% endif %}
             
                {#icône panier #}
                <a href="{{ path('app_menu_index') }}" class="navbar-icon" title="Commander">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                       <line x1="3" y1="6" x2="21" y2="6"/>
                       <path d="M16 10a4 4 0 0 1-8 0"/>
                       </svg>
                </a>

              </div>
          </div>
            
            
            {# menu mobile#}
             <div class="collapse navbar-collapse" id="navMenu">
                 <div class="navbar-nav-mobile py-2">
                         <a href="{{ path('app_home') }}" class="nav-link py-2">Accueil</a>
                         <a href="{{ path('app_menu_index') }}" class="nav-link py-2">Nos menus</a>
                         <a href="{{ path('app_avis_liste') }}" class="nav-link py-2">Vos avis</a>
                         <a href="{{ path('app_contact') }}" class="nav-link py-2">Contact</a>
                     {% if app.user %}
                         {% if is_granted('ROLE_ADMIN') %}
                                  <a href="{{ path('app_admin_dashboard') }}" class="nav-link py-2">Espace Admin</a>
                         {% elseif is_granted('ROLE_EMPLOYE') %}
                                 <a href="{{ path('app_employe_dashboard') }}" class="nav-link py-2">Espace Employé</a>
                         {% else %}
                                 <a href="{{ path('app_user_dashboard') }}" class="nav-link py-2">Mon compte</a>
                         {% endif %}
                             <a href="{{ path('app_logout') }}" class="nav-link py-2">Déconnexion</a>
                     {% else %}
                             <a href="{{ path('app_login') }}" class="nav-link py-2">Connexion</a>
                             <a href="{{ path('app_register') }}" class="nav-link py-2">S'inscrire</a>
                     {% endif %}
                 </div>
             </div>

          </div>
       </nav>

       {#msg flash (ex: identifiants incorrects)#}
        <div class="container-xl px-4 mt-3">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                   <div class="alert alert-{{ type }} alert-dismissible fade show">
                       {{ message }}
                       <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                  </div>
                {% endfor %}
            {% endfor %}
        </div>

      {#contenu principal#}                
        <main id="main">
           {% block body %}{% endblock %}
        </main>
      
       {#footer#}
         <footer class="footer py-5">
             <div class="container-xl px-4">
               <div class="row g-4">

                 {#colonne1#}
                 <div class="col-12 col-md-6 col-lg-3">
                     <div class="footer-brand">Vite &amp; Gourmand</div>
                     <p>Bordeaux depuis 1999</p>
                     <p>contact@viteetgourmand.fr</p>
                 </div>

                 {#colonne horaire dynmq BDD #}
                 <div class="col-12 col-md-6 col-lg-2">
                     <h5>HORAIRES</h5>
                     {% if horaires is defined and horaires|length > 0 %}
                         {% for horaire in horaires %}
                             <p class="small mb-1">
                                 {{ horaire.jour }} :
                                 {% if horaire.heureOuverture|date('H:i') == '00:00' %}
                                     Fermé
                                 {% else %}
                                     {{ horaire.heureOuverture|date('H:i') }}–{{ horaire.heureFermeture|date('H:i') }}
                                 {% endif %}
                             </p>
                         {% endfor %}
                      {% endif %}
                 </div>

                 {#colonne à propos #}
                 <div class="col-12 col-md-6 col-lg-2">
                     <h5>À PROPOS</h5>
                     <a href="{{ path('app_home') }}">Qui sommes-nous ?</a>
                     <a href="{{ path('app_menu_index') }}">Nos menus</a>
                     <a href="{{ path('app_avis_liste') }}">Les avis</a>
                     <a href="{{ path('app_contact') }}">Nous contacter</a>
                     <a href="#">FAQ</a>
                 </div>

                 {#colonne infos légales #}
                 <div class="col-12 col-md-6 col-lg-2">
                     <h5>INFORMATIONS</h5>
                     <a href="#">Mentions légales</a>
                     <a href="#">CGV</a>
                     <a href="#">CGU</a>
                     <a href="#">Politique de confidentialité</a>
                     <a href="#">Cookies</a>
                 </div>

               </div>

               {#cpyright #}
               <hr class="footer-hr mt-4 mb-3">
               <p class="footer-copyright">
                 &copy; {{ "now"|date("Y") }} Vite &amp; Gourmand — Tous droits réservés
               </p>
             </div>
         </footer>
       
       
       {#bootstrap js#}  
       <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
       
       {#js global#} 
       <script src="{{ asset('js/app.js') }}"></script> 
       
       {# JS spécifique à la page #}
       {% block page_js %}{% endblock %}

    </body>
</html>
