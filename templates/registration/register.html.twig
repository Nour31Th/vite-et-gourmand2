{# template pr page inscription, création compte client,#}

{% extends 'base.html.twig' %}

{% block title %}Inscription — Vite & Gourmand{% endblock %}

{% block page_css %}
    <link rel="stylesheet" href="{{ asset('css/forms.css') }}">
{% endblock %}

{% block body %}

<div class="hero-bandeau">
    <h1 class="hero-titre">Créer un compte</h1>
</div>

<section class="login-container">
    <div style="width:100%;max-width:600px">
        <div class="login-card">

            {# novalidate->désac valida° HTML5 native, valida° gérée dans RegistrationController #}
            <form action="{{ path('app_register') }}" method="post" novalidate>

                {#token csrf#}
                <input type="hidden" name="_token"
                       value="{{ csrf_token('register') }}">

                {#prenom et nom#}
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label for="prenom" class="form-label">Prénom *</label>
                        <input type="text" id="prenom" name="prenom"
                               class="form-control"
                               autocomplete="given-name" required>
                    </div>
                    <div class="col-md-6">
                        <label for="nom" class="form-label">Nom *</label>
                        <input type="text" id="nom" name="nom"
                               class="form-control"
                               autocomplete="family-name" required>
                    </div>
                </div>

                {#gsm#}
                <div class="mb-3">
                    <label for="gsm" class="form-label">Téléphone</label>
                    <input type="tel" id="gsm" name="gsm"
                           class="form-control"
                           autocomplete="tel">
                </div>

                {adresse, pré-remplie dans commande #}
                <div class="mb-3">
                    <label for="adresse" class="form-label">Adresse</label>
                    <input type="text" id="adresse" name="adresse"
                           class="form-control"
                           autocomplete="street-address">
                </div>

                {#ville et CP#}
                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <label for="ville" class="form-label">Ville</label>
                        <input type="text" id="ville" name="ville"
                               class="form-control"
                               autocomplete="address-level2">
                    </div>
                    <div class="col-md-4">
                        <label for="code_postal" class="form-label">Code postal</label>
                        <input type="text" id="code_postal" name="code_postal"
                               class="form-control"
                               autocomplete="postal-code">
                    </div>
                </div>

                {#mail, id connexion #}
                <div class="mb-3">
                    <label for="email" class="form-label">Email *</label>
                    <input type="email" id="email" name="email"
                           class="form-control"
                           placeholder="votre@email.fr"
                           autocomplete="email" required>
                </div>

                {#mdp#}
                <div class="mb-3">
                    <label for="password" class="form-label">Mot de passe *</label>
                    <input type="password" id="password" name="password"
                           class="form-control"
                           autocomplete="new-password" required>
                    {#hint->règles de complexité du mdp #}
                    <div class="form-hint">
                        10 caractères minimum · 1 majuscule · 1 chiffre · 1 caractère spécial
                    </div>
                </div>

                {#cgu #}
                <div class="mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               id="agreeTerms" name="agree_terms" required>
                        <label class="form-cgu-label" for="agreeTerms">
                            J'accepte les
                            <a href="#" class="form-lien-inscription">
                                conditions générales d'utilisation
                            </a>
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-vert w-100 mb-3">
                    Créer mon compte
                </button>

            </form>

            <hr class="form-hr">

            <div class="login-footer">
                Déjà un compte ?
                <a href="{{ path('app_login') }}" class="form-lien-inscription">
                    Se connecter
                </a>
            </div>

        </div>
    </div>
</section>

{% endblock %}
