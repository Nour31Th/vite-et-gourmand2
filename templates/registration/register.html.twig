{# template pr page inscription, création compte client#}

{% extends 'base.html.twig' %}

{% block title %}Inscription Vite & Gourmand{% endblock %}

{% block page_css %}
   <link rel="stylesheet" href="{{ asset('css/forms.css') }}">    {# cf fichier css #}
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="login-card">
        
        <div class="login-header">
            <h1 class="login-titre"> Créer un compte</h1>
            <p class="login-sous-titre">Rejoignez Vite & Gourmand</p>
        </div>

        <form action="{{ path('app_register') }}" method="post">                                  {# formulaire inscript°, act°--> envoie données vers POST /register, method="post" --> obligatoire pr envoyer données sécu#} 
               <input type="hidden" name="_token" value="{{ csrf_token('register') }}">           {#protect° c/ attaques #}
               
               <div class="mb-3">                                               {# champ nom #}
                    <label for="nom" class="form-label">Nom *</label>
                    <input type="text"
                       id="nom"
                       name="nom"
                       class="form-control"
                       placeholder="Votre nom"
                       required>
               </div>

               <div class="mb-3">                                              {# champ prénom #}
                    <label for="prenom" class="form-label">Prénom *</label>
                    <input type="text"
                       id="prenom"
                       name="prenom"
                       class="form-control"
                       placeholder="Votre prénom"
                       required>
               </div>

               <div class="mb-3">                                             {# Champ email type="email" active la validation HTML5 #}
                    <label for="email" class="form-label">Email *</label>
                    <input type="email"
                       id="email"
                       name="email"
                       class="form-control"
                       placeholder="votre@email.fr"
                       required>
               </div>

               <div class="mb-3">                                                    {# Champ mot de passe — type="password" masque la saisie #}
                    <label for="password" class="form-label">Mot de passe *</label>
                    <input type="password"
                       id="password"
                       name="password"
                       class="form-control"
                       placeholder="8 caractères minimum"
                       required>
               </div>

               <div class="mb-3">                                                       {# Confirma° mdp, vérif côté serveur dans controller #}
                    <label for="confirm_password" class="form-label">Confirmer le mot de passe *</label>
                    <input type="password"
                       id="confirm_password"
                       name="confirm_password"
                       class="form-control"
                       placeholder="Retapez votre mot de passe"
                       required>
               </div>

               <div class="d-grid mt-4">                          {# Btn soumettre formulaire#}
                   <button type="submit" class="btn btn-vert">
                     Créer mon compte
                   </button>
               </div>
        </form>

        <div class="login-footer mt-3">                           {# Lien page de connex° pr user d&jà inscrits #}
            <span>Déjà un compte ?</span>
            <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </div>
</div>
{% endblock %}
