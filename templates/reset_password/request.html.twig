{# Formulaire demande réinitialisa° mdp #}
{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — Vite & Gourmand{% endblock %}

{% block page_css %}
    <link rel="stylesheet" href="{{ asset('css/forms.css') }}">
{% endblock %}

{% block body %}

<div class="hero-bandeau">
    <h1 class="hero-titre">Mot de passe oublié</h1>
</div>

<section class="login-container">
    <div style="width:100%;max-width:480px">
        <div class="login-card">

            <div class="login-header">
                <h2 class="login-titre">Réinitialiser mon mot de passe</h2>
                <p class="login-sous-titre">
                    Saisissez votre email pour recevoir un lien de réinitialisation.
                </p>
            </div>

            <form action="{{ path('app_reset_password') }}" method="post">

                {#token csrf #}
                <input type="hidden" name="_token"
                       value="{{ csrf_token('reset_password') }}">

                <div class="mb-4">
                    <label for="email" class="form-label">Adresse email</label>
                    <input type="email" id="email" name="email"
                           class="form-control"
                           placeholder="votre@email.fr"
                           autocomplete="email" required>
                </div>

                <button type="submit" class="btn btn-vert w-100 mb-3">
                    Envoyer le lien
                </button>

            </form>

            <hr class="form-hr">

            <div class="login-footer">
                <a href="{{ path('app_login') }}" class="form-lien-oubli">
                    Retour à la connexion
                </a>
            </div>

        </div>
    </div>
</section>

{% endblock %}