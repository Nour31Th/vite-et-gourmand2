{# Formulaire new mdp, user a cliqué lien reçu par mail avant #}

{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — Vite & Gourmand{% endblock %}

{% block page_css %}
    <link rel="stylesheet" href="{{ asset('css/forms.css') }}">
{% endblock %}

{% block body %}

<div class="hero-bandeau">
    <h1 class="hero-titre">Nouveau mot de passe</h1>
</div>

<section class="login-container">
    <div style="width:100%;max-width:480px">
        <div class="login-card">

            <div class="login-header">
                <h2 class="login-titre">Choisir un nouveau mot de passe</h2>
            </div>

            <form action="{{ path('app_reset_password_confirm', {selector: selector}) }}"
                  method="post">

                {#token csrf#}
                <input type="hidden" name="_token"
                       value="{{ csrf_token('reset_confirm') }}">

                {#token secret reçu via GET, renvoyé au controller pr vérif° #}
                <input type="hidden" name="token" value="{{ token }}">

                <div class="mb-3">
                    <label for="password" class="form-label">Nouveau mot de passe</label>
                    <input type="password" id="password" name="password"
                           class="form-control"
                           placeholder="8 caractères minimum"
                           autocomplete="new-password" required>
                </div>

                <div class="mb-4">
                    <label for="confirm_password" class="form-label">
                        Confirmer le mot de passe
                    </label>
                    <input type="password" id="confirm_password" name="confirm_password"
                           class="form-control"
                           placeholder="Retapez votre mot de passe"
                           autocomplete="new-password" required>
                </div>

                <button type="submit" class="btn btn-vert w-100">
                    Enregistrer le mot de passe
                </button>

            </form>

        </div>
    </div>
</section>

{% endblock %}