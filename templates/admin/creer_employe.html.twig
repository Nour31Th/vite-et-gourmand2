{#template créa° compte employé#}

{% extends 'base.html.twig' %}

{% block title %}Créer un employé — Vite & Gourmand{% endblock %}

{% block page_css %}
    <link rel="stylesheet" href="{{ asset('css/forms.css') }}">
{% endblock %}

{% block body %}

<div class="dashboard-bandeau">
    <h1 class="dashboard-bandeau-titre">Créer un compte employé</h1>
</div>

<section class="section-commande">
    <div class="container-xl px-4">

        <a href="{{ path('app_admin_employes') }}" class="lien-retour">
            ← Retour aux employés
        </a>

        <div class="row justify-content-center mt-3">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="commande-card">

                    <form action="{{ path('app_admin_creer_employe') }}" method="post">

                        <input type="hidden" name="_token"
                               value="{{ csrf_token('creer_employe') }}">

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="nom" class="form-label">Nom *</label>
                                <input type="text" id="nom" name="nom"
                                       class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label for="prenom" class="form-label">Prénom *</label>
                                <input type="text" id="prenom" name="prenom"
                                       class="form-control" required>
                            </div>
                            <div class="col-12">
                                <label for="email" class="form-label">Email *</label>
                                <input type="email" id="email" name="email"
                                       class="form-control" required>
                            </div>
                            <div class="col-12">
                                <label for="gsm" class="form-label">Téléphone</label>
                                <input type="tel" id="gsm" name="gsm"
                                       class="form-control">
                            </div>
                            <div class="col-12">
                                <label for="password" class="form-label">Mot de passe *</label>
                                <input type="password" id="password" name="password"
                                       class="form-control"
                                       placeholder="8 caractères minimum"
                                       required>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-vert">
                                Créer le compte employé
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}