{#template stats admin
graphique Chart.js, données PostgreSQL (MongoDB sur feature/mongodb)
variables :total_commandes->nb total commandes, commandes_par_mois->tableau [{mois, nb}]#}

{% extends 'base.html.twig' %}

{% block title %}Statistiques — Vite & Gourmand{% endblock %}

{% block page_css %}
    <link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
{% endblock %}

{% block body %}

<div class="dashboard-bandeau">
    <h1 class="dashboard-bandeau-titre">Statistiques</h1>
</div>

<section class="section-dashboard">
    <div class="container-xl px-4">

        <div class="dashboard-onglets mb-4">
            <a href="{{ path('app_admin_dashboard') }}" class="btn btn-sm btn-outline-secondary">Commandes</a>
            <a href="{{ path('app_admin_employes') }}" class="btn btn-sm btn-outline-secondary">Employés</a>
            <a href="{{ path('app_admin_avis') }}" class="btn btn-sm btn-outline-secondary">Avis</a>
            <a href="{{ path('app_admin_stats') }}" class="btn btn-sm btn-brun">Statistiques</a>
            <a href="{{ path('app_admin_horaires') }}" class="btn btn-sm btn-outline-secondary">Horaires</a>
            <a href="{{ path('app_employe_menus') }}" class="btn btn-sm btn-outline-secondary">Menus</a>
        </div>

        {#total commandes #}
        <div class="row g-4 mb-4">
            <div class="col-12 col-md-4">
                <div class="stat-card">
                    <div class="stat-nombre">{{ total_commandes }}</div>
                    <div class="stat-label">Commandes totales</div>
                </div>
            </div>
        </div>

        {#graphique commandes/mois — Chart.js #}
        <div class="commande-card mb-4">
            <h2 class="commande-section-titre">Commandes par mois</h2>
            <canvas id="chartCommandes" height="100"></canvas>
        </div>

    </div>
</section>

{% endblock %}

{% block page_js %}
    {# Chart.js via CDN #}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
    /*stat mensuel commande (chart.js), rendu visuel alimenté par injecteur twig (admincontreoller)*/
    document.addEventListener('DOMContentLoaded', function () {

        //données transmises depuis Twig via json_encode
        const data = {{ commandes_par_mois|json_encode|raw }};

        //labels (mois) et valeurs (nb commandes)
        const labels = data.map(d => d.mois ?? d[0] ?? '');
        const values = data.map(d => parseInt(d.nb ?? d[1] ?? 0));

        const ctx = document.getElementById('chartCommandes').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Commandes',
                    data: values,
                    backgroundColor: '#5C7A5C',
                    borderRadius: 4,
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });

    });
    </script>
{% endblock %}
