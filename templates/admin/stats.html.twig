{#template stats admin
graphique Chart.js, données PostgreSQL, composant mongodb dédié
variables :total_commandes->nb total commandes (PostgreSQL), stats_by_menu->menus les+ commandés (MongoDB), stats_by_mois->commandes/mois (MongoDB), ca_total->CA total (MongoDB)#}

{% extends 'base.html.twig' %}

{% block title %}Statistiques — Vite & Gourmand{% endblock %}

{% block page_css %}
    <link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">
{% endblock %}

{% block body %}

<div class="dashboard-bandeau">
    <h1 class="dashboard-bandeau-titre">Statistiques</h1>
</div>

<section class="section-dashboard">
    <div class="container-xl px-4">

        {#onglet#}
        <div class="dashboard-onglets mb-4">
            <a href="{{ path('app_admin_dashboard') }}" class="btn btn-sm btn-outline-secondary">Commandes</a>
            <a href="{{ path('app_admin_employes') }}" class="btn btn-sm btn-outline-secondary">Employés</a>
            <a href="{{ path('app_admin_avis') }}" class="btn btn-sm btn-outline-secondary">Avis</a>
            <a href="{{ path('app_admin_stats') }}" class="btn btn-sm btn-brun">Statistiques</a>
            <a href="{{ path('app_admin_horaires') }}" class="btn btn-sm btn-outline-secondary">Horaires</a>
            <a href="{{ path('app_employe_menus') }}" class="btn btn-sm btn-outline-secondary">Menus</a>
        </div>

        {#stat#}
        <div class="row g-4 mb-4">
            <div class="col-12 col-md-4">
                <div class="stat-card">
                    <div class="stat-nombre">{{ total_commandes }}</div>
                    <div class="stat-label">Commandes totales</div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="stat-card">
                    <div class="stat-nombre">{{ ca_total|number_format(2) }} €</div>
                    <div class="stat-label">Chiffre d'affaires (MongoDB)</div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="stat-card">
                    <div class="stat-nombre">{{ stats_by_menu|length }}</div>
                    <div class="stat-label">Menus différents commandés</div>
                </div>
            </div>
        </div>

        {#graphique commandes/mois #}
        <div class="commande-card mb-4">
            <h2 class="commande-section-titre">Commandes par mois (MongoDB)</h2>
            <canvas id="chartMois" height="80"></canvas>
        </div>

        {#graphique menus les+commandés #}
        <div class="commande-card mb-4">
            <h2 class="commande-section-titre">Menus les plus commandés (MongoDB)</h2>
            <canvas id="chartMenus" height="80"></canvas>
        </div>

    </div>
</section>

{% endblock %}

{% block page_js %}
   <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    {#passe données PHP vers JS via data-attributes pr éviter JS inline dans template Twig#}
    <div id="stats-data"
         data-mois="{{ stats_by_mois|json_encode|e('html_attr') }}"
         data-menus="{{ stats_by_menu|json_encode|e('html_attr') }}">
    </div>
    
   <scriptsrc="{{ asset('js/stats.js') }}"></script>
{% endblock %}
